#!/bin/bash
# DeapX OS — cleanup chroot hook
set -e

echo "Cleaning up package cache and temporary files inside chroot..."
apt-get clean
rm -rf /var/lib/apt/lists/*
rm -rf /tmp/*
rm -rf /var/tmp/*
rm -f /etc/ssh/ssh_host_* 2>/dev/null || true
rm -f /root/.bash_history 2>/dev/null || true
history -c 2>/dev/null || true
