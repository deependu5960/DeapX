#!/bin/bash

# DeapX Live Build - Auto Configuration
# DX-005.1.1 Base ISO Foundation

set -e

lb config noauto \
    --distribution bookworm \
    --architectures amd64 \
    --archive-areas "main contrib non-free non-free-firmware" \
    --binary-images iso-hybrid \
    --bootappend-live "boot=live components quiet splash" \
    --debian-installer false \
    --iso-application "DeapX" \
    --iso-volume "DeapX Live" \
    --memtest none \
    --firmware-binary true \
    --firmware-chroot true \
    --apt-recommends true \
    --apt-indices false \
    --cache false \
    --checksums sha256 \
    --image-name "DeapX" \
    --win32-loader false \
    "${@}"